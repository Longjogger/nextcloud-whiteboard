# This file is used to set environment variables for the Nextcloud Whiteboard application.

# Your Nextcloud instance URL
NC_URL=https://your-nextcloud-domain.de

# A random secret key for JWT authentication (should be kept secret in production)
JWT_SECRET_KEY=some_random_secret

# Maximum upload file size (important for image uploads, e.g., 10 for 10 megabytes)
MAX_UPLOAD_FILE_SIZE=10